<?xml version="1.0" encoding="utf-8"?>
<!-- Единый фон виджетов: тёмная полупрозрачная скруглённая карточка.
     Тёмная, потому что иконки и подписи белые — на светлом фоне они бы исчезали.
     Одинакова в светлой и тёмной теме → консистентный вид независимо от обоев. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="28dp" />
    <solid android:color="#C01C1F24" />
    <stroke android:width="1dp" android:color="#33FFFFFF" />
</shape>
