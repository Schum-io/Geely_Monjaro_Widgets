<?xml version="1.0" encoding="utf-8"?>
<!-- Фон виджетов — СВЕТЛАЯ тема. Мягкий бело-голубой градиент как в оригинале
     (oneOS_BTPhone: res/drawable/widget_bg_new.png). Тёмный вариант — в
     drawable-night/widget_frame.xml. Иконки и подписи в светлой теме тёмные
     (#2D3035), в тёмной — белые. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="28dp" />
    <gradient
        android:type="linear"
        android:angle="270"
        android:startColor="#EFF5FE"
        android:endColor="#D9E4F6" />
    <stroke android:width="1dp" android:color="#1A2D3035" />
</shape>
