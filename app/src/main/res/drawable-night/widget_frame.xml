<?xml version="1.0" encoding="utf-8"?>
<!-- Фон виджетов — ТЁМНАЯ тема. Тёмный сине-серый градиент как в оригинале
     (oneOS_BTPhone: res/drawable-night/widget_bg_new.png). Иконки и подписи
     в тёмной теме белые. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="28dp" />
    <gradient
        android:type="linear"
        android:angle="270"
        android:startColor="#323844"
        android:endColor="#191F29" />
    <stroke android:width="1dp" android:color="#33FFFFFF" />
</shape>
