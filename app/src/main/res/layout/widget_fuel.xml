<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/widget_frame"
    android:padding="10dp"
    android:clickable="true"
    android:focusable="true">

    <FrameLayout
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginBottom="4dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/climate_circle_off"
            android:contentDescription="circle" />

        <ImageView
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_fuel"
            android:contentDescription="@string/fuel_label" />
    </FrameLayout>

    <TextView
        android:id="@+id/fuelPercent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="—"
        android:textColor="@color/widget_label_text"
        android:fontFamily="sans-serif-medium"
        android:textStyle="bold"
        android:textSize="22sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/fuel_label"
        android:textColor="@color/widget_label_text"
        android:fontFamily="sans-serif-medium"
        android:textSize="13sp" />

</LinearLayout>
